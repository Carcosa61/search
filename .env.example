# Environment Variables — copy to .env and fill in values

# Database
DB_PASSWORD=changeme

# OpenAI (optional — leave blank to disable AI summarisation)
OPENAI_API_KEY=

# Ollama local LLM (optional — used when OPENAI_API_KEY is blank)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Alert delivery
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# App settings
SECRET_KEY=change-this-secret-key
